#include <stdlib.h>

typedef struct{
    int inf, sup;
} Intervalo;


int existe(int x, Intervalo c[], int N){
    if(N == 0) return -1;

    int thereis = 0;
    while(thereis){
        for(int i = 0; i < N; i ++){
            if(x >= c[i].inf && x <= c[i].sup){
                thereis = 1;
            }
        }
    } return 0;
}

int acrescenta(Intervalo a, Intervalo c[], int N){
    if(N==0) return 1;

    for(int i = 0; i < N; i++){
        if(a.inf == c[i].inf && a.sup == c[i].sup) return 0;
    }

    int pos = N;
    int i = 0;

    while(i < N && pos){
        if(a.inf < c[i].inf){
            pos = i;
        }
    }


    for(int i = N; i > pos; i --){
        c[i] = c[i - 1];
    }

    return N + 1;
}

typedef struct no{
    int valor;
    struct no *prox;
} *LInt;

int listToArray(LInt l, int v[], int N){
    if(!l) return 0;

    int i = 0; 

    while(l){
        v[i] = l -> valor;
        l = l -> prox;
        i++;
    }

    return i;
}

typedef struct nodo{
    int valor;
    struct nodo *l, *r;
} *ABin;


int ehFolhaProfunda(ABin a){
    if(!a) return 0;

    ehFolhaProfunda(a -> l);
    if(!a -> l){
        ehFolhaProfunda(a -> r);
    } else {
        return 1;
    }
}

ABin folhaMaisProfunda(ABin a){

    if(!a) return 0;

    if(ehFolhaProfunda(a) == 1) return a;
}


int delete(int n, LInt * l){
    if(!(*l)) return 0;

    LInt *curr = l;

    while((*curr) != NULL){
        if((*curr) -> valor == n){
            LInt temp = (*curr);
            *curr = (*curr) -> prox;
            free(temp);
        }

        curr = &((*curr) -> prox);
    }

    return 1;
}