#include <stdio.h>
#include <stdlib.h>


int pesquisa(int a[], int N, int x){
    int i = 0;

    while(i < N){
        if(x == a[i]) return i;
        i++;
    }

    return -1;
}


typedef struct LInt_nodo{
    int valor;
    struct LInt_nodo *prox;
} *LInt;


void roda(LInt *l){

    if(!(*l)) return;

   LInt previous = NULL;
   LInt current = *l;

    while(current -> prox != NULL){
        previous = current;
        current = current -> prox;
    }

    previous -> prox = NULL;
    current -> prox = *l;
    *l = current;
    
}

typedef struct ABin_nodo{
    int valor;
    struct ABin_nodo *esq, *dir;
} *ABin;


int apaga(ABin a, int n){
    int contador = 0;
    if(!a) return 0;

    if(n == 0) return 0;
    
    int nodesL = apaga(a -> esq, n);
    int nodesR = apaga(a -> dir, n - nodesL);

    if(!(a -> esq) && !(a -> dir)){
        free(a);
        a = NULL;
        return nodesL + nodesR + 1;
    }

    return nodesL + nodesR;
}